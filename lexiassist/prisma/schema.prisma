datasource db {
  provider  = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  CLIENT
  LAWYER
  ADMIN
}

enum CaseStatus {
  TRIAGE
  REVIEW
  MATCHED
  RESOLVED
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  name          String?
  role          UserRole        @default(CLIENT)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  // Relations
  lawyerProfile LawyerProfile?
  clientCases    CaseBrief[]    @relation("ClientCases")
  agentSessions  AgentSession[] @relation("ClientSessions") // <-- NEW
  
  @@index([email])
  @@index([role])
}

model LawyerProfile {
  id             String         @id @default(uuid())
  userId         String         @unique
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization String[]       // e.g., ["Corporate", "Family Law"]
  jurisdiction   String         // Geographic matching region
  experienceYrs  Int
  isAvailable    Boolean        @default(true)
  
  // Relations
  assignedCases  CaseBrief[]    @relation("LawyerCases")

  // Indexes specific to Lawyer searches
  @@index([userId])
  @@index([jurisdiction])
  @@index([isAvailable])
}

model CaseBrief {
  id             String         @id @default(uuid())
  clientId       String
  client         User           @relation("ClientCases", fields: [clientId], references: [id])
  lawyerId       String?
  lawyer         LawyerProfile? @relation("LawyerCases", fields: [lawyerId], references: [id])
  
  title          String
  rawDescription String         @db.Text
  status         CaseStatus     @default(TRIAGE)
  
  // AI Generated Structured Outputs stored safely as JSON
  aiTimeline     Json?          // Structured chronological array of events
  aiEntities     Json?          // Extracted names, business names, dates
  aiRiskAnalysis Json?          // Key legal vulnerabilities identified by LLM
  estimatedValue Float?
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  // Relations
  consultations  Consultation[]
  agentSessions  AgentSession[] @relation("CaseSessions")
  documents       Document[]

  // Indexes correctly placed for Case queries
  @@index([clientId])
  @@index([lawyerId])
  @@index([status])
}

model Consultation {
  id           String     @id @default(uuid())
  caseBriefId  String
  caseBrief    CaseBrief  @relation(fields: [caseBriefId], references: [id], onDelete: Cascade)
  
  webrtcRoomId String     @unique // Unique meeting identifier for frontend matching
  scheduledAt  DateTime
  isCompleted  Boolean    @default(false)
  
  createdAt    DateTime   @default(now())

  // Indexes for WebRTC and case lookups
  @@index([caseBriefId])
  @@index([webrtcRoomId])
}

model AgentSession {
  id          String     @id @default(uuid())
  clientId    String     // Ties to the User model id
  user        User       @relation("ClientSessions", fields: [clientId], references: [id], onDelete: Cascade)
  caseBriefId String?  
  caseBrief   CaseBrief? @relation("CaseSessions", fields: [caseBriefId], references: [id], onDelete: SetNull)
  status      String     @default("PROCESSING") // Can be PROCESSING, COMPLETED, or FAILED
  content     String?    @db.Text // Where the final AI response goes
  metadata    Json?      // Stores what step the AI is on
  messages    Json?      // for conversation history
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([clientId])
  @@index([status])
}

model Document {
  id            String     @id @default(uuid())
  caseBriefId   String
  caseBrief     CaseBrief  @relation(fields: [caseBriefId], references: [id], onDelete: Cascade)
  fileUrl       String
  extractedText String     @db.Text
  redlines      Json?      // populated by generateDocumentRedlines
  createdAt     DateTime   @default(now())

  @@index([caseBriefId])
}
